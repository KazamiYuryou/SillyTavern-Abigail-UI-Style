    "replaceString":  "\u003cdiv class=\"abby-bridge\" style=\"display:none\"\u003e\n  \u003cspan class=\"abby-raw-name\"\u003e$1\u003c/span\u003e\n  \u003cspan class=\"abby-raw-mood\"\u003e$2\u003c/span\u003e\n  \u003cdiv class=\"abby-raw-content\"\u003e$3\u003c/div\u003e\n\u003c/div\u003e\n\u003cscript\u003e\n(() =\u003e {\n  const bridge = document.currentScript \u0026\u0026 document.currentScript.previousElementSibling;\n  if (!bridge) return;\n\n  const name = (bridge.querySelector(\u0027.abby-raw-name\u0027)?.textContent || \u0027\u0027).trim() || \u0027阿比盖尔\u0027;\n  const moodRaw = (bridge.querySelector(\u0027.abby-raw-mood\u0027)?.textContent || \u0027\u0027).trim();\n  const contentHtml = (bridge.querySelector(\u0027.abby-raw-content\u0027)?.innerHTML || \u0027\u0027).trim();\n\n  const moodAlias = {\n    \u0027高兴\u0027: \u0027高兴\u0027, \u0027开心\u0027: \u0027高兴\u0027, \u0027喜悦\u0027: \u0027高兴\u0027,\n    \u0027悲伤\u0027: \u0027悲伤\u0027, \u0027难过\u0027: \u0027悲伤\u0027,\n    \u0027害羞\u0027: \u0027害羞\u0027,\n    \u0027生气\u0027: \u0027生气\u0027, \u0027愤怒\u0027: \u0027生气\u0027,\n    \u0027疑惑\u0027: \u0027疑惑\u0027, \u0027困惑\u0027: \u0027疑惑\u0027\n  };\n\n  const mood = moodAlias[moodRaw] || \u0027高兴\u0027;\n  const skinRaw = (typeof getVar === \u0027function\u0027 \u0026\u0026 getVar(\u0027system_skin\u0027) !== undefined) ? String(getVar(\u0027system_skin\u0027)) : \u00270\u0027;\\n  const skinSafe = /^(0|1|2|3)$/.test(skinRaw) ? skinRaw : \u00270\u0027;\n  const portraitUrl = `https://cdn.jsdelivr.net/gh/AkabaneSaki/myrepo@main/picture/abby/${mood}${skin}.png`;\n\n  const target = document.body;\n  const templateUrl = \u0027http://localhost:5500/%E5%91%BD%E5%AE%9A/%E7%BE%8E%E5%8C%96/regex-%E9%98%BF%E6%AF%94%E7%9B%96%E5%B0%94%E6%A0%B8%E5%BF%83%E7%BE%8E%E5%8C%96-%E8%A1%A8%20(%E7%BE%8E%E5%8C%962)-replaceString.html\u0027;\n\n  if (typeof $ !== \u0027function\u0027) return;\n\n  $(target).load(templateUrl, () =\u003e {\n    const root = target.querySelector(\u0027.abby-yog-card\u0027);\n    if (!root) return;\n\n    const nameEl = root.querySelector(\u0027.abby-name-text\u0027);\n    const contentEl = root.querySelector(\u0027.abby-yog-content\u0027);\n    const portraitEl = root.querySelector(\u0027.portrait-inner\u0027);\n\n    if (nameEl) nameEl.textContent = name;\n    if (contentEl) contentEl.innerHTML = contentHtml || \u0027「Master，阿比在这里。」\u0027;\n\n    if (portraitEl) {\n      portraitEl.style.backgroundImage = `url(\u0027${portraitUrl}\u0027)`;\n      const img = new Image();\n      img.onerror = () =\u003e {\n        portraitEl.style.backgroundImage = \"url(\u0027https://cdn.jsdelivr.net/gh/AkabaneSaki/myrepo@main/picture/abby/高兴0.png\u0027)\";\n      };\n      img.src = portraitUrl;\n    }\n  });\n})();\n\u003c/script\u003e",
