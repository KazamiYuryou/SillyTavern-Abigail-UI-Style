{
    "id": "0c2255cb-9c9d-44fa-9d02-f8661e5110b7",
    "scriptName": "命定核心-阿比盖尔美化-表(二选一)",
    "findRegex": "/<Foreigner\\s+name=[\"'](.*?)[\"']\\s+mood=[\"'](.*?)[\"'][^>]*>\\s*[「]?\\s*([\\s\\S]*?)\\s*[」]?\\s*<\\/Foreigner>/g",
    "replaceString": "<div class=\"abby-yog-card\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Noto+Serif+SC:wght@400;700&display=swap\" rel=\"stylesheet\">\n\n  <div class=\"bg-container\">\n    <div class=\"void-base\"></div>\n    <div class=\"star-layer stars-main\"></div>\n    <div class=\"snow-layer\" aria-hidden=\"true\"></div>\n  </div>\n\n  <div class=\"scan-beam\"></div>\n\n  <div class=\"solar-key-system\">\n    <div class=\"zero-anchor\">\n      <div class=\"orbit-ring ring-outer\"></div>\n      <div class=\"orbit-ring ring-inner\"></div>\n      <div class=\"eldritch-key-group\">\n        <div class=\"ek-handle\"></div>\n        <div class=\"ek-shaft\"></div>\n        <div class=\"ek-bit\"></div>\n      </div>\n      <div class=\"center-pivot\"></div>\n    </div>\n  </div>\n\n  <div class=\"portrait-wrapper\">\n    <div class=\"portrait-frame-rect\">\n      <div class=\"portrait-inner\" style=\"background-image: url('https://cdn.jsdelivr.net/gh/AkabaneSaki/myrepo@main/picture/abby/$2{{getVar::system_skin}}.png');\"></div>\n      <div class=\"frame-overlay\"></div>\n    </div>\n  </div>\n\n  <div class=\"content-wrapper\">\n    <div class=\"abby-yog-header\">\n      <div class=\"header-deco-left\">✦</div>\n      <span class=\"abby-name-text\">$1</span>\n      <div class=\"header-line-grow\"></div>\n    </div>\n    <div class=\"abby-yog-content\">$3</div>\n  </div>\n</div>\n\n<style>\n.abby-yog-card{\n  position:relative;\n  margin:20px 0 20px 10px;\n  padding:20px;\n  overflow:hidden;\n  z-index:1;\n  --base-blue:#4a5a8a;\n  --light-blue:#a8c0ff;\n  --glow-blue:rgba(168,192,255,0.75);\n  --mithril-white:#f0f8ff;\n  --void-deep:#05081c;\n  font-family:'Noto Serif SC','Times New Roman',serif;\n  color:#f0f4f8;\n  border:1px solid var(--base-blue);\n  border-radius:12px;\n  box-shadow:0 0 15px rgba(74,90,138,0.35),0 10px 30px rgba(0,0,0,0.55);\n  transition:all .4s ease;\n  min-height:240px;\n  display:block;\n  contain:layout paint style;\n  content-visibility:auto;\n  contain-intrinsic-size:420px 260px;\n}\n\n.bg-container{\n  position:absolute;\n  inset:0;\n  overflow:hidden;\n  z-index:-2;\n  border-radius:11px;\n  background-color:var(--void-deep);\n}\n\n.void-base{\n  position:absolute;\n  inset:0;\n  background:\n    radial-gradient(120% 90% at 70% 15%, rgba(76,96,160,.28), transparent 58%),\n    radial-gradient(95% 85% at 20% 80%, rgba(64,40,128,.22), transparent 62%),\n    radial-gradient(circle at 60% 40%, #1a1f35 0%, var(--void-deep) 78%);\n}\n\n.star-layer{\n  position:absolute;\n  inset:-28%;\n  width:156%;\n  height:156%;\n  background-image:url('https://www.transparenttextures.com/patterns/stardust.png');\n  background-repeat:repeat;\n  background-size:420px;\n  opacity:.46;\n  pointer-events:none;\n}\n\n/* 按用户要求：仅保留 1 个慢速旋转星层 */\n.stars-main{\n  transform-origin:52% 48%;\n  animation:star-spin 320s linear infinite;\n}\n\n/* 轻量雪尘层：低开销、保留“下雪感” */\n.snow-layer,\n.snow-layer::before,\n.snow-layer::after{\n  position:absolute;\n  inset:-8%;\n  pointer-events:none;\n}\n.snow-layer,\n.snow-layer::before,\n.snow-layer::after{\n  content:'';\n  background-repeat:repeat;\n  background-size:220px 220px;\n  animation:snow-fall linear infinite;\n}\n.snow-layer{\n  opacity:.34;\n  background-image:radial-gradient(circle, rgba(255,255,255,.9) 1px, transparent 1.5px);\n  animation-duration:22s;\n}\n.snow-layer::before{\n  opacity:.22;\n  background-image:radial-gradient(circle, rgba(220,235,255,.8) 1px, transparent 1.6px);\n  animation-duration:30s;\n  animation-delay:-8s;\n  transform:translateX(18px);\n}\n.snow-layer::after{\n  opacity:.14;\n  background-image:radial-gradient(circle, rgba(200,220,255,.7) .9px, transparent 1.5px);\n  animation-duration:38s;\n  animation-delay:-14s;\n  transform:translateX(-14px);\n}\n\n.scan-beam{\n  position:absolute;\n  inset:0;\n  pointer-events:none;\n  z-index:2;\n  overflow:hidden;\n}\n.scan-beam::after{\n  content:'';\n  position:absolute;\n  top:-20%;\n  left:-55%;\n  width:38%;\n  height:140%;\n  background:linear-gradient(90deg,transparent,rgba(168,192,255,.12),rgba(255,255,255,.2),rgba(168,192,255,.12),transparent);\n  transform:skewX(-20deg);\n  opacity:0;\n  transition:transform .85s ease, opacity .5s ease;\n}\n.abby-yog-card:hover .scan-beam::after{\n  transform:translateX(255%) skewX(-20deg);\n  opacity:.8;\n}\n\n.portrait-wrapper{\n  position:absolute;\n  top:25px;\n  left:25px;\n  z-index:10;\n}\n.portrait-frame-rect{\n  width:120px;\n  height:160px;\n  border:2px double var(--light-blue);\n  box-shadow:0 5px 20px rgba(0,0,0,.6),0 0 10px rgba(74,90,138,.25);\n  overflow:hidden;\n  background:#02040a;\n  transform:rotate(-1deg);\n  border-radius:3px;\n  transition:transform .35s ease, box-shadow .35s ease;\n}\n.portrait-frame-rect:hover{\n  transform:rotate(0deg) scale(1.04);\n  box-shadow:0 8px 22px rgba(0,0,0,.68),0 0 12px var(--glow-blue);\n  border-color:var(--mithril-white);\n}\n.portrait-inner{\n  width:100%;\n  height:100%;\n  background-size:cover;\n  background-position:center top;\n  filter:contrast(1.08) saturate(1.08);\n}\n.frame-overlay{\n  position:absolute;\n  inset:0;\n  background:linear-gradient(to bottom, transparent 60%, rgba(5,8,28,.8));\n  pointer-events:none;\n  box-shadow:inset 0 0 10px rgba(5,8,28,.5);\n}\n\n.content-wrapper{margin-left:160px;position:relative;z-index:5}\n.abby-yog-header{\n  position:relative;\n  display:flex;\n  align-items:center;\n  margin-bottom:15px;\n  z-index:2;\n  padding-right:10px;\n  border-bottom:1px dotted var(--base-blue);\n  padding-bottom:10px;\n}\n.header-deco-left{\n  color:var(--light-blue);\n  font-size:1.2em;\n  margin-right:10px;\n  text-shadow:0 0 5px var(--glow-blue);\n  animation:star-pulse 5s ease-in-out infinite;\n}\n.abby-name-text{\n  font-family:'Cinzel',serif;\n  font-size:1.5em;\n  font-weight:700;\n  color:#fff;\n  letter-spacing:2px;\n  text-shadow:0 0 8px var(--light-blue);\n  white-space:nowrap;\n  overflow:hidden;\n  text-overflow:ellipsis;\n}\n.header-line-grow{\n  flex-grow:1;\n  height:2px;\n  background:linear-gradient(90deg,var(--base-blue),transparent);\n  margin-left:15px;\n  opacity:.72;\n  transition:all .35s ease;\n}\n.abby-yog-card:hover .header-line-grow{\n  opacity:1;\n  background:linear-gradient(90deg,var(--light-blue),transparent);\n  box-shadow:0 0 8px var(--glow-blue);\n}\n.abby-yog-content{\n  position:relative;\n  z-index:2;\n  color:#f0f4f8;\n  font-size:1.05em;\n  line-height:1.75;\n  text-shadow:0 1px 2px rgba(0,0,0,.8);\n  padding:10px 5px;\n  font-family:'Noto Serif SC',serif;\n}\n\n.solar-key-system{\n  position:absolute;\n  bottom:15px;\n  right:15px;\n  width:60px;\n  height:60px;\n  z-index:10;\n  pointer-events:none;\n}\n.zero-anchor{position:absolute;top:50%;left:50%;width:0;height:0}\n.orbit-ring{position:absolute;border-radius:50%;transition:all .35s ease}\n.ring-outer{\n  width:50px;height:50px;top:-25px;left:-25px;\n  background:repeating-conic-gradient(from 0deg,var(--light-blue) 0deg 2deg,transparent 2deg 28deg);\n  -webkit-mask:radial-gradient(transparent 62%, black 63%);\n  mask:radial-gradient(transparent 62%, black 63%);\n  opacity:.7;\n  animation:mech-spin 48s linear infinite;\n}\n.ring-inner{\n  width:34px;height:34px;top:-17px;left:-17px;\n  background:repeating-conic-gradient(from 0deg,rgba(168,192,255,.78) 0deg 1.5deg,transparent 1.5deg 11deg);\n  -webkit-mask:radial-gradient(transparent 58%, black 59%);\n  mask:radial-gradient(transparent 58%, black 59%);\n  opacity:.52;\n  animation:ring-spin-rev 34s linear infinite;\n}\n.abby-yog-card:hover .ring-outer{opacity:.9;animation-duration:32s}\n.abby-yog-card:hover .ring-inner{opacity:.72;animation-duration:24s}\n\n.eldritch-key-group{\n  position:absolute;top:0;left:0;width:0;height:0;\n  animation:mech-spin 28s linear infinite;\n  z-index:15;\n}\n.ek-handle{\n  position:absolute;width:12px;height:12px;top:-6px;left:-6px;\n  transform:rotate(45deg);\n  border:2px double var(--mithril-white);\n  box-shadow:0 0 4px var(--glow-blue);\n  background:rgba(0,0,0,.25);\n}\n.ek-handle::after{content:'';position:absolute;inset:2px;border:1px solid var(--light-blue);background:var(--glow-blue);opacity:.42}\n.ek-shaft{position:absolute;width:25px;height:3px;top:-1.5px;left:0;background:linear-gradient(to bottom,#8a9bb8,#ffffff 50%,#8a9bb8);transform-origin:left center;border-radius:0 2px 2px 0}\n.ek-bit{position:absolute;width:5px;height:9px;top:0;left:19px;background:var(--mithril-white);-webkit-mask:conic-gradient(from 45deg at 2px 2px, transparent 270deg, black 0deg),linear-gradient(to bottom, black 40%, transparent 40%, transparent 60%, black 60%);-webkit-mask-composite:xor;mask-composite:exclude;box-shadow:2px 0 0 var(--mithril-white)}\n.ek-bit::before{content:'';position:absolute;top:2px;left:-2px;width:3px;height:6px;border-right:2px solid var(--mithril-white);border-top:2px solid var(--mithril-white);border-bottom:2px solid var(--mithril-white)}\n.abby-yog-card:hover .eldritch-key-group{animation-duration:20s}\n.center-pivot{position:absolute;top:-2px;left:-2px;width:4px;height:4px;background:#fff;border-radius:50%;box-shadow:0 0 4px #fff,0 0 6px var(--light-blue);z-index:20}\n\n@media only screen and (max-width:768px){\n  .abby-yog-card{display:flex;flex-direction:column;padding:15px;min-height:auto}\n  .portrait-wrapper{position:relative;top:0;left:0;width:100%;display:flex;align-items:center;gap:10px;margin-bottom:12px;border-bottom:1px dashed rgba(168,192,255,.3);padding-bottom:10px;justify-content:center}\n  .portrait-frame-rect{width:80px;height:107px;border-width:1px;transform:rotate(0deg);box-shadow:0 2px 8px rgba(0,0,0,.5)}\n  .content-wrapper{margin-left:0}\n  .abby-yog-header{display:flex;margin-bottom:10px;padding-right:0}\n  .abby-name-text{font-size:1.3em}\n  .abby-yog-content{font-size:.95em;padding:0}\n}\n\n@media (prefers-reduced-motion:reduce){\n  .stars-main,.snow-layer,.snow-layer::before,.snow-layer::after,.header-deco-left,.ring-outer,.ring-inner,.eldritch-key-group{animation:none!important}\n  .scan-beam::after{transition:none}\n}\n\n@keyframes snow-fall{\n  0%{transform:translate3d(0,-8%,0)}\n  100%{transform:translate3d(0,8%,0)}\n}\n@keyframes star-spin{100%{transform:rotate(360deg)}}\n@keyframes star-pulse{0%,100%{transform:scale(1);opacity:.72}50%{transform:scale(1.12);opacity:1}}\n@keyframes mech-spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}\n@keyframes ring-spin-rev{0%{transform:rotate(360deg)}100%{transform:rotate(0deg)}}\n</style>",
