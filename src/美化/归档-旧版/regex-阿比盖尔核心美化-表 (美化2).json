    "replaceString":  "\u003cdiv class=\"abby-yog-card\"\u003e\n  \u003clink href=\"https://fonts.googleapis.com/css2?family=Cinzel:wght@700\u0026family=Noto+Serif+SC:wght@400;700\u0026display=swap\" rel=\"stylesheet\"\u003e\n\n  \u003cdiv class=\"bg-container\"\u003e\n    \u003cdiv class=\"void-base\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"galaxy-arm arm-primary\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"galaxy-arm arm-secondary\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"star-layer stars-dense-1\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"star-layer stars-dense-2\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"star-layer stars-dense-3\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"star-layer stars-dense-4\"\u003e\u003c/div\u003e\n    \u003cdiv class=\"particle-layer p1\"\u003e\u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003cdiv class=\"scan-beam\"\u003e\u003c/div\u003e\n\n  \u003cdiv class=\"solar-key-system\"\u003e\n    \u003cdiv class=\"zero-anchor\"\u003e\n      \u003cdiv class=\"dimension-ripple\"\u003e\u003c/div\u003e\n      \u003cdiv class=\"orbit-ring ring-outer\"\u003e\u003c/div\u003e\n      \u003cdiv class=\"orbit-ring ring-inner\"\u003e\u003c/div\u003e\n      \u003cdiv class=\"eldritch-key-group\"\u003e\n        \u003cdiv class=\"ek-handle\"\u003e\u003c/div\u003e\n        \u003cdiv class=\"ek-shaft\"\u003e\u003c/div\u003e\n        \u003cdiv class=\"ek-bit\"\u003e\u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class=\"center-pivot\"\u003e\u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003cdiv class=\"portrait-wrapper\"\u003e\n    \u003cdiv class=\"portrait-frame-rect\"\u003e\n      \u003cdiv class=\"portrait-inner\" style=\"background-image: url(\u0027https://cdn.jsdelivr.net/gh/AkabaneSaki/myrepo@main/picture/abby/$2{{getVar::system_skin}}.png\u0027);\"\u003e\u003c/div\u003e\n      \u003cdiv class=\"frame-overlay\"\u003e\u003c/div\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003cdiv class=\"content-wrapper\"\u003e\n    \u003cdiv class=\"abby-yog-header\"\u003e\n      \u003cdiv class=\"header-deco-left\"\u003e\u0026#10022;\u003c/div\u003e\n      \u003cspan class=\"abby-name-text\"\u003e$1\u003c/span\u003e\n      \u003cdiv class=\"header-line-grow\"\u003e\u003c/div\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"abby-yog-content\"\u003e$3\u003c/div\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003cstyle\u003e\n.abby-yog-card{\n  position:relative;\n  margin:clamp(12px,2.4vw,24px) auto;\n  width:min(100%, clamp(320px, 94vw, 1180px));\n  padding:clamp(14px, 2.2vw, 26px);\n  overflow:hidden;\n  z-index:1;\n  --base-blue:#4a5a8a;\n  --light-blue:#a8c0ff;\n  --glow-blue:rgba(168,192,255,.8);\n  --mithril-white:#f0f8ff;\n  --void-deep:#05081c;\n  --blur-strength:clamp(48px, 6vw, 110px);\n  --star-scale:clamp(.72, .55 + .06vw, 1.45);\n  --portrait-w:clamp(92px, 12vw, 142px);\n  --portrait-h:calc(var(--portrait-w) * 1.33);\n  font-family:\u0027Noto Serif SC\u0027,\u0027Times New Roman\u0027,\u0027Noto Sans Symbols 2\u0027,\u0027Segoe UI Symbol\u0027,serif;\n  color:#f0f4f8;\n  border:1px solid var(--base-blue);\n  border-radius:12px;\n  box-shadow:0 0 15px rgba(74,90,138,0.4),0 8px 24px rgba(0,0,0,0.55);\n  transition:all .45s cubic-bezier(.25,.8,.25,1);\n  contain:layout paint style;\n  content-visibility:auto;\n  contain-intrinsic-size:480px 280px;\n}\n\n.bg-container{position:absolute;inset:0;overflow:hidden;z-index:-2;border-radius:11px;background-color:var(--void-deep)}\n.void-base{position:absolute;inset:0;background:radial-gradient(circle at 50% 50%, #1a1f35 0%, var(--void-deep) 80%);z-index:-1}\n.galaxy-arm{position:absolute;width:300%;height:300%;filter:blur(var(--blur-strength));mix-blend-mode:screen;opacity:.4;pointer-events:none}\n.arm-primary{top:-100%;left:-100%;transform-origin:20% 80%;background:conic-gradient(from 0deg at 50% 50%,transparent 0deg,transparent 140deg,rgba(74,20,140,.3) 180deg,rgba(168,192,255,.1) 220deg,transparent 260deg,transparent 360deg);animation:mech-spin 120s linear infinite}\n.arm-secondary{top:-100%;left:-100%;transform-origin:80% 20%;background:conic-gradient(from 180deg at 50% 50%,transparent 0deg,transparent 120deg,rgba(0,229,255,.15) 160deg,rgba(168,192,255,.05) 200deg,transparent 240deg,transparent 360deg);animation:mech-spin 90s linear infinite reverse}\n\n.star-layer{position:absolute;inset:-100%;width:300%;height:300%;background-image:url(\u0027https://www.transparenttextures.com/patterns/stardust.png\u0027);background-repeat:repeat;mix-blend-mode:screen;pointer-events:none;transition:opacity 2s ease, transform .5s ease}\n.stars-dense-1{transform-origin:33% 28%;background-size:calc(350px * var(--star-scale));opacity:.55;animation:star-spin 240s linear infinite}\n.stars-dense-2{transform-origin:72% 75%;background-size:calc(600px * var(--star-scale));opacity:.45;animation:star-spin 180s linear infinite reverse}\n.stars-dense-3{transform-origin:20% 85%;background-size:calc(900px * var(--star-scale));opacity:.35;animation:star-spin 140s linear infinite reverse}\n.stars-dense-4{transform-origin:85% 15%;background-size:calc(1300px * var(--star-scale));opacity:.25;animation:star-spin 200s linear infinite}\n.abby-yog-card:hover .star-layer{opacity:.7;filter:brightness(1.4);animation-duration:120s, 90s, 70s, 100s}\n.particle-layer{position:absolute;inset:-100%;background-image:radial-gradient(1px 1px at 50% 50%,#fff,transparent);background-size:calc(350px * var(--star-scale));opacity:.2;z-index:0;animation:pan-slow 60s linear infinite}\n\n.scan-beam{position:absolute;inset:0;pointer-events:none;z-index:2;overflow:hidden}\n.scan-beam::after{content:\u0027\u0027;position:absolute;top:0;left:-100%;width:50%;height:200%;background:linear-gradient(90deg,transparent,rgba(168,192,255,.05),rgba(255,255,255,.12),rgba(168,192,255,.05),transparent);transform:skewX(-20deg) translateY(-25%);animation:smart-scan 20s linear infinite}\n.abby-yog-card:hover .scan-beam::after{animation-duration:12s;background:linear-gradient(90deg,transparent,rgba(168,192,255,.08),rgba(255,255,255,.2),rgba(168,192,255,.08),transparent)}\n\n.portrait-wrapper{position:absolute;top:clamp(16px,2.1vw,28px);left:clamp(16px,2.1vw,28px);z-index:10}\n.portrait-frame-rect{position:relative;width:var(--portrait-w);height:var(--portrait-h);border:2px double var(--light-blue);box-shadow:0 5px 20px rgba(0,0,0,.6),0 0 10px rgba(74,90,138,.25);overflow:hidden;background:#02040a;transform:rotate(-1deg);border-radius:3px;transition:transform .35s ease, box-shadow .35s ease}\n.portrait-frame-rect:hover{transform:rotate(0deg) scale(1.04);box-shadow:0 8px 22px rgba(0,0,0,.68),0 0 12px var(--glow-blue);border-color:var(--mithril-white)}\n.portrait-inner{width:100%;height:100%;background-size:cover;background-position:center top;filter:contrast(1.08) saturate(1.08)}\n.frame-overlay{position:absolute;inset:0;background:linear-gradient(to bottom, transparent 60%, rgba(5,8,28,.8));pointer-events:none;box-shadow:inset 0 0 10px rgba(5,8,28,.5)}\n\n.content-wrapper{position:relative;z-index:5;margin-left:calc(var(--portrait-w) + clamp(18px,2vw,28px));min-height:var(--portrait-h)}\n.abby-yog-header{position:relative;display:flex;align-items:center;margin-bottom:15px;z-index:2;padding-right:clamp(14px,2.2vw,84px);border-bottom:1px dotted var(--base-blue);padding-bottom:10px}\n.header-deco-left{color:var(--light-blue);font-size:1.2em;margin-right:10px;text-shadow:0 0 5px var(--glow-blue);animation:star-pulse 3s infinite}\n.abby-name-text{font-family:\u0027Cinzel\u0027,\u0027Noto Sans Symbols 2\u0027,\u0027Segoe UI Symbol\u0027,serif;font-size:clamp(1.18em, 1.08em + .35vw, 1.56em);font-weight:700;color:#fff;letter-spacing:2px;text-shadow:0 0 8px var(--light-blue);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n.header-line-grow{flex-grow:1;height:2px;background:linear-gradient(90deg,var(--base-blue),transparent);margin-left:15px;opacity:.7;transition:all .5s ease}\n.abby-yog-card:hover .header-line-grow{opacity:1;background:linear-gradient(90deg,var(--light-blue),transparent);box-shadow:0 0 10px var(--glow-blue)}\n.abby-yog-content{position:relative;z-index:2;color:#f0f4f8;font-size:clamp(.95em, .9em + .18vw, 1.08em);line-height:1.75;text-shadow:0 1px 2px rgba(0,0,0,.8);padding:10px 5px;font-family:\u0027Noto Serif SC\u0027,serif}\n\n.solar-key-system{position:absolute;top:15px;right:15px;width:60px;height:60px;z-index:10;pointer-events:none}\n.zero-anchor{position:absolute;top:50%;left:50%;width:0;height:0}\n.dimension-ripple{position:absolute;top:0;left:0;transform:translate(-50%,-50%);width:0;height:0;border-radius:50%;border:1px solid rgba(168,192,255,.6);opacity:0;transition:all .5s ease}\n.abby-yog-card:hover .dimension-ripple{animation:ripple-burst 1.5s ease-out infinite}\n.orbit-ring{position:absolute;border-radius:50%;transition:all .5s cubic-bezier(.34,1.56,.64,1)}\n.ring-outer{width:50px;height:50px;top:-25px;left:-25px;background:repeating-conic-gradient(from 0deg,var(--light-blue) 0deg 3deg,transparent 3deg 30deg);-webkit-mask:radial-gradient(transparent 62%,black 63%);mask:radial-gradient(transparent 62%,black 63%);opacity:.8;animation:mech-spin 40s linear infinite}\n.ring-inner{width:36px;height:36px;top:-18px;left:-18px;background:repeating-conic-gradient(from 0deg,var(--glow-blue) 0deg 2deg,transparent 2deg 10deg);-webkit-mask:radial-gradient(transparent 58%,black 59%);mask:radial-gradient(transparent 58%,black 59%);opacity:.6;animation:ring-spin-rev 25s linear infinite}\n.abby-yog-card:hover .ring-outer{width:74px;height:74px;top:-37px;left:-37px;opacity:1;filter:drop-shadow(0 0 4px var(--light-blue));animation-duration:20s}\n.abby-yog-card:hover .ring-inner{width:48px;height:48px;top:-24px;left:-24px;opacity:.9;animation-duration:12s}\n.eldritch-key-group{position:absolute;top:0;left:0;width:0;height:0;animation:mech-spin 20s linear infinite;z-index:15;filter:drop-shadow(0 0 2px rgba(168,192,255,.5))}\n.ek-handle{position:absolute;width:12px;height:12px;top:-6px;left:-6px;transform:rotate(45deg);border:2px double var(--mithril-white);box-shadow:0 0 5px var(--glow-blue);background:rgba(0,0,0,.3)}\n.ek-handle::after{content:\u0027\u0027;position:absolute;inset:2px;border:1px solid var(--light-blue);background:var(--glow-blue);opacity:.5}\n.ek-shaft{position:absolute;width:25px;height:3px;top:-1.5px;left:0;background:linear-gradient(to bottom,#8a9bb8,#ffffff 50%,#8a9bb8);transform-origin:left center;border-radius:0 2px 2px 0}\n.ek-bit{position:absolute;width:5px;height:9px;top:0;left:19px;background:var(--mithril-white);-webkit-mask:conic-gradient(from 45deg at 2px 2px,transparent 270deg,black 0deg),linear-gradient(to bottom,black 40%,transparent 40%,transparent 60%,black 60%);-webkit-mask-composite:xor;mask-composite:exclude;box-shadow:2px 0 0 var(--mithril-white)}\n.ek-bit::before{content:\u0027\u0027;position:absolute;top:2px;left:-2px;width:3px;height:6px;border-right:2px solid var(--mithril-white);border-top:2px solid var(--mithril-white);border-bottom:2px solid var(--mithril-white)}\n.abby-yog-card:hover .eldritch-key-group{animation-duration:8s;filter:drop-shadow(0 0 6px var(--light-blue)) brightness(1.2)}\n.center-pivot{position:absolute;top:-2px;left:-2px;width:4px;height:4px;background:#fff;border-radius:50%;box-shadow:0 0 4px #fff,0 0 8px var(--light-blue);z-index:20}\n\n@media only screen and (max-width:768px){\n  .abby-yog-card{display:flex;flex-direction:column;padding:15px;width:min(100%,96vw)}\n  .portrait-wrapper{position:relative;top:0;left:0;width:100%;display:flex;align-items:center;gap:10px;margin-bottom:12px;border-bottom:1px dashed rgba(168,192,255,.3);padding-bottom:10px;justify-content:center}\n  .portrait-frame-rect{width:80px;height:107px;border-width:1px;transform:rotate(0deg);box-shadow:0 2px 8px rgba(0,0,0,.5)}\n  .content-wrapper{margin-left:0;min-height:auto}\n  .abby-yog-header{display:flex;margin-bottom:10px;padding-right:0}\n  .abby-name-text{font-size:1.3em}\n  .abby-yog-content{font-size:.95em;padding:0}\n  .solar-key-system{top:auto;bottom:12px;right:12px;opacity:.9}\n}\n\n@media (min-width:1440px){\n  .abby-yog-card{width:min(100%, clamp(920px, 70vw, 1280px))}\n}\n\n@media (prefers-reduced-motion:reduce){\n  .galaxy-arm,.star-layer,.particle-layer,.scan-beam::after,.dimension-ripple,.header-deco-left,.ring-outer,.ring-inner,.eldritch-key-group{animation:none!important}\n}\n\n@keyframes smart-scan{0%{left:-100%;opacity:0}5%{opacity:1}85%{left:200%;opacity:1}86%{opacity:0}100%{left:200%;opacity:0}}\n@keyframes pan-slow{0%{transform:translate(0,0)}100%{transform:translate(-100px,-100px)}}\n@keyframes ripple-burst{0%{width:0;height:0;border-width:2px;opacity:.8}100%{width:100px;height:100px;border-width:0;opacity:0}}\n@keyframes star-pulse{0%,100%{transform:scale(1);opacity:.7}50%{transform:scale(1.3) rotate(45deg);opacity:1}}\n@keyframes star-spin{100%{transform:rotate(360deg)}}\n@keyframes mech-spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}\n@keyframes ring-spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
@keyframes ring-spin-rev{0%{transform:rotate(360deg)}100%{transform:rotate(0deg)}}\n\u003c/style\u003e",
